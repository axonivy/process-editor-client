{
  "private": true,
  "name": "parent",
  "version": "10.0.1",
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "ci": "npm install && npm run build && npm run package && npm run lint:ci && npm run test:ci",
    "clean": "lerna run clean",
    "build": "lerna run build",
    "package": "lerna run package",
    "type": "lerna run type",
    "lint": "lerna run lint --",
    "dev": "npm run --workspace=@ivyteam/standalone-integration dev",
    "dev:eclipse": "npm run --workspace=@ivyteam/eclipse-integration dev",
    "test": "lerna run test",
    "test:win": "lerna run test:win",
    "test:ci": "lerna run test:ci",
    "webtest": "lerna run webtest --",
    "publish:package": "lerna publish from-package --exact --dist-tag=sprint --yes"
  },
  "devDependencies": {
    "@types/node": "^16.11.36",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "eslint": "^8.3.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-no-null": "^1.0.2",
    "ignore-styles": "^5.0.1",
    "lerna": "^4.0.0",
    "prettier": "^2.4.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.7.0",
    "typescript": "^4.5.2"
  },
  "workspaces": {
    "packages": [
      "editor",
      "integration/standalone",
      "integration/eclipse"
    ]
  },
  "volta": {
    "node": "18.19.0"
  }
}
