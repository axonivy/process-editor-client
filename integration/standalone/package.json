{
  "private": true,
  "name": "@ivyteam/standalone-integration",
  "version": "10.0.1",
  "description": "Standalone browser-app for the Axon Ivy process editor",
  "author": "Axon Ivy AG",
  "homepage": "https://developer.axonivy.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/axonivy/glsp-editor-client"
  },
  "dependencies": {
    "@eclipse-glsp/client": "1.1.0-RC02",
    "@ivyteam/process-editor": "^10.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.30.0",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "eslint": "^8.3.0",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-no-null": "^1.0.2",
    "reflect-metadata": "^0.2.0",
    "typescript": "^4.6.3",
    "vite": "^5.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "path-browserify": "^1.0.1",
    "os-browserify": "^0.3.0",
    "crypto-browserify": "^3.12.1",
    "net-browserify": "^0.2.4",
    "stream-browserify": "^3.0.0",
    "buffer-browserify": "^0.2.5",
    "vite-plugin-node-polyfills": "^0.23.0",
    "setimmediate": "^1.0.5"
  },
  "type": "module",
  "scripts": {
    "clean": "rimraf lib build/*",
    "lint": "eslint -c ./.eslintrc.js --ext .ts,.tsx ./src",
    "type": "tsc --noEmit",
    "build": "tsc --build",
    "package": "vite build",
    "dev": "vite",
    "serve": "vite preview",
    "webtest": "playwright test",
    "webtest:ci": "PLAYWRIGHT_JUNIT_OUTPUT_NAME=report.xml playwright test"
  }
}
